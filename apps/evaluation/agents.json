{
  "schema": "acp-eval-agents/v1",
  "agents": [
    {
      "agent_id": "knowledge-agent",
      "dir": "python/agents/knowledge",
      "report_command": [
        "uv",
        "run",
        "--directory",
        "python",
        "python",
        "-m",
        "knowledge_agent.eval_report",
        "--out",
        "{out}"
      ]
    },
    {
      "agent_id": "cloud-agent",
      "dir": "agents/cloud",
      "report_command": ["node", "agents/cloud/dist/eval-report.js", "--out", "{out}"]
    },
    {
      "agent_id": "code-agent",
      "dir": "agents/code",
      "report_command": ["node", "agents/code/dist/eval-report.js", "--out", "{out}"]
    },
    {
      "agent_id": "change-agent",
      "dir": "agents/change",
      "report_command": ["node", "agents/change/dist/eval-report.js", "--out", "{out}"]
    }
  ]
}
