{
  "description": "Golden allow/deny suite for the active bundle. Every permit policy must determine at least one allow case; every case's verdict is asserted in CI — a policy change that flips untested territory fails the build.",
  "cases": [
    {
      "name": "tenant user delegates an R0 capability to a same-tenant agent",
      "expect": "allow",
      "determined_by": "allow-r0-delegation",
      "request": {
        "principal": { "type": "User", "id": "user:jane.doe", "attrs": { "tenant": "acme" } },
        "action": "delegate",
        "resource": { "type": "Agent", "id": "knowledge-agent", "attrs": { "tenant": "acme" } },
        "context": { "risk": "R0", "scopes": ["task:submit", "knowledge:search:read"] }
      }
    },
    {
      "name": "R1 delegation has no permit in v0",
      "expect": "deny",
      "request": {
        "principal": { "type": "User", "id": "user:jane.doe", "attrs": { "tenant": "acme" } },
        "action": "delegate",
        "resource": { "type": "Agent", "id": "change-agent", "attrs": { "tenant": "acme" } },
        "context": { "risk": "R1", "scopes": ["task:submit"] }
      }
    },
    {
      "name": "cross-tenant delegation is denied",
      "expect": "deny",
      "request": {
        "principal": { "type": "User", "id": "user:mallory", "attrs": { "tenant": "globex" } },
        "action": "delegate",
        "resource": { "type": "Agent", "id": "knowledge-agent", "attrs": { "tenant": "acme" } },
        "context": { "risk": "R0", "scopes": ["task:submit"] }
      }
    },
    {
      "name": "delegation without task:submit scope is denied",
      "expect": "deny",
      "request": {
        "principal": { "type": "User", "id": "user:jane.doe", "attrs": { "tenant": "acme" } },
        "action": "delegate",
        "resource": { "type": "Agent", "id": "knowledge-agent", "attrs": { "tenant": "acme" } },
        "context": { "risk": "R0", "scopes": ["knowledge:search:read"] }
      }
    },
    {
      "name": "agent with delegated knowledge scope searches its tenant corpus",
      "expect": "allow",
      "determined_by": "allow-knowledge-read",
      "request": {
        "principal": {
          "type": "Agent",
          "id": "agent:knowledge-agent@0.1.0",
          "attrs": { "tenant": "acme" }
        },
        "action": "knowledge.search",
        "resource": { "type": "Corpus", "id": "acme", "attrs": { "tenant": "acme" } },
        "context": { "scopes": ["knowledge:search:read"] }
      }
    },
    {
      "name": "answer_with_citations rides the same knowledge-read permit",
      "expect": "allow",
      "determined_by": "allow-knowledge-read",
      "request": {
        "principal": {
          "type": "Agent",
          "id": "agent:knowledge-agent@0.1.0",
          "attrs": { "tenant": "acme" }
        },
        "action": "knowledge.answer_with_citations",
        "resource": { "type": "Corpus", "id": "acme", "attrs": { "tenant": "acme" } },
        "context": { "scopes": ["knowledge:search:read"] }
      }
    },
    {
      "name": "agent without the knowledge scope is denied at the query path",
      "expect": "deny",
      "request": {
        "principal": {
          "type": "Agent",
          "id": "agent:rogue-agent@0.0.1",
          "attrs": { "tenant": "acme" }
        },
        "action": "knowledge.search",
        "resource": { "type": "Corpus", "id": "acme", "attrs": { "tenant": "acme" } },
        "context": { "scopes": [] }
      }
    },
    {
      "name": "agent cannot search another tenant's corpus even with the scope",
      "expect": "deny",
      "request": {
        "principal": {
          "type": "Agent",
          "id": "agent:knowledge-agent@0.1.0",
          "attrs": { "tenant": "globex" }
        },
        "action": "knowledge.search",
        "resource": { "type": "Corpus", "id": "acme", "attrs": { "tenant": "acme" } },
        "context": { "scopes": ["knowledge:search:read"] }
      }
    },
    {
      "name": "tenant user delegates R0 cloud capabilities to the cloud agent",
      "expect": "allow",
      "determined_by": "allow-r0-delegation",
      "request": {
        "principal": { "type": "User", "id": "user:jane.doe", "attrs": { "tenant": "acme" } },
        "action": "delegate",
        "resource": { "type": "Agent", "id": "cloud-agent", "attrs": { "tenant": "acme" } },
        "context": {
          "risk": "R0",
          "scopes": ["task:submit", "cloud:inventory:read", "cloud:cost:read"]
        }
      }
    },
    {
      "name": "tenant user delegates R0 code capabilities to the code agent",
      "expect": "allow",
      "determined_by": "allow-r0-delegation",
      "request": {
        "principal": { "type": "User", "id": "user:jane.doe", "attrs": { "tenant": "acme" } },
        "action": "delegate",
        "resource": { "type": "Agent", "id": "code-agent", "attrs": { "tenant": "acme" } },
        "context": {
          "risk": "R0",
          "scopes": ["task:submit", "code:repo:read", "code:ci:read"]
        }
      }
    },
    {
      "name": "cloud agent calls inventory_search through the gateway PEP (the Item 3 deny pin, flipped consciously)",
      "expect": "allow",
      "determined_by": "allow-tool-cloud-estate-inventory",
      "request": {
        "principal": {
          "type": "Agent",
          "id": "agent:cloud-agent@0.1.0",
          "attrs": { "tenant": "acme" }
        },
        "action": "tool:cloud-estate:inventory_search",
        "resource": { "type": "Service", "id": "svc:cloud-estate", "attrs": {} },
        "context": { "scopes": ["cloud:inventory:read", "cloud:cost:read"], "tenant": "acme" }
      }
    },
    {
      "name": "agent calling a tool outside its manifest scopes is denied — cloud scopes open no code-forge door",
      "expect": "deny",
      "request": {
        "principal": {
          "type": "Agent",
          "id": "agent:cloud-agent@0.1.0",
          "attrs": { "tenant": "acme" }
        },
        "action": "tool:code-forge:repo_dependencies",
        "resource": { "type": "Service", "id": "svc:code-forge", "attrs": {} },
        "context": { "scopes": ["cloud:inventory:read", "cloud:cost:read"], "tenant": "acme" }
      }
    },
    {
      "name": "cloud agent calls cost_report through the gateway PEP",
      "expect": "allow",
      "determined_by": "allow-tool-cloud-estate-cost",
      "request": {
        "principal": {
          "type": "Agent",
          "id": "agent:cloud-agent@0.1.0",
          "attrs": { "tenant": "acme" }
        },
        "action": "tool:cloud-estate:cost_report",
        "resource": { "type": "Service", "id": "svc:cloud-estate", "attrs": {} },
        "context": { "scopes": ["cloud:inventory:read", "cloud:cost:read"], "tenant": "acme" }
      }
    },
    {
      "name": "code agent calls repo_dependencies through the gateway PEP",
      "expect": "allow",
      "determined_by": "allow-tool-code-forge-repo",
      "request": {
        "principal": {
          "type": "Agent",
          "id": "agent:code-agent@0.1.0",
          "attrs": { "tenant": "acme" }
        },
        "action": "tool:code-forge:repo_dependencies",
        "resource": { "type": "Service", "id": "svc:code-forge", "attrs": {} },
        "context": { "scopes": ["code:repo:read", "code:ci:read"], "tenant": "acme" }
      }
    },
    {
      "name": "code agent calls ci_runs through the gateway PEP",
      "expect": "allow",
      "determined_by": "allow-tool-code-forge-ci",
      "request": {
        "principal": {
          "type": "Agent",
          "id": "agent:code-agent@0.1.0",
          "attrs": { "tenant": "acme" }
        },
        "action": "tool:code-forge:ci_runs",
        "resource": { "type": "Service", "id": "svc:code-forge", "attrs": {} },
        "context": { "scopes": ["code:repo:read", "code:ci:read"], "tenant": "acme" }
      }
    },
    {
      "name": "tenant user calls knowledge_search through the gateway PEP (IDE-shaped access)",
      "expect": "allow",
      "determined_by": "allow-tool-knowledge-search",
      "request": {
        "principal": { "type": "User", "id": "user:jane.doe", "attrs": { "tenant": "acme" } },
        "action": "tool:knowledge:knowledge_search",
        "resource": { "type": "Service", "id": "svc:knowledge", "attrs": {} },
        "context": { "scopes": ["knowledge:search:read"], "tenant": "acme" }
      }
    },
    {
      "name": "tenant user searches the corpus at the inner knowledge PEP",
      "expect": "allow",
      "determined_by": "allow-knowledge-user-read",
      "request": {
        "principal": { "type": "User", "id": "user:jane.doe", "attrs": { "tenant": "acme" } },
        "action": "knowledge.search",
        "resource": { "type": "Corpus", "id": "acme", "attrs": { "tenant": "acme" } },
        "context": { "scopes": ["knowledge:search:read"], "tenant": "acme" }
      }
    },
    {
      "name": "agent with an empty delegated scope set cannot call inventory_search",
      "expect": "deny",
      "request": {
        "principal": {
          "type": "Agent",
          "id": "agent:cloud-agent@0.1.0",
          "attrs": { "tenant": "acme" }
        },
        "action": "tool:cloud-estate:inventory_search",
        "resource": { "type": "Service", "id": "svc:cloud-estate", "attrs": {} },
        "context": { "scopes": [], "tenant": "acme" }
      }
    },
    {
      "name": "user without the knowledge-read scope cannot call knowledge_search",
      "expect": "deny",
      "request": {
        "principal": { "type": "User", "id": "user:jane.doe", "attrs": { "tenant": "acme" } },
        "action": "tool:knowledge:knowledge_search",
        "resource": { "type": "Service", "id": "svc:knowledge", "attrs": {} },
        "context": { "scopes": ["task:submit"], "tenant": "acme" }
      }
    },
    {
      "name": "R2 delegation with task:submit lifts to require-approval (gated, not allowed)",
      "expect": "require-approval",
      "determined_by": "gate-r2-delegation",
      "request": {
        "principal": { "type": "User", "id": "user:jane.doe", "attrs": { "tenant": "acme" } },
        "action": "delegate",
        "resource": { "type": "Agent", "id": "change-agent", "attrs": { "tenant": "acme" } },
        "context": { "risk": "R2", "scopes": ["task:submit"] }
      }
    },
    {
      "name": "R2 cross-tenant delegation is denied, never gated",
      "expect": "deny",
      "request": {
        "principal": { "type": "User", "id": "user:mallory", "attrs": { "tenant": "globex" } },
        "action": "delegate",
        "resource": { "type": "Agent", "id": "change-agent", "attrs": { "tenant": "acme" } },
        "context": { "risk": "R2", "scopes": ["task:submit"] }
      }
    },
    {
      "name": "R2 delegation without task:submit is denied, never gated",
      "expect": "deny",
      "request": {
        "principal": { "type": "User", "id": "user:jane.doe", "attrs": { "tenant": "acme" } },
        "action": "delegate",
        "resource": { "type": "Agent", "id": "change-agent", "attrs": { "tenant": "acme" } },
        "context": { "risk": "R2", "scopes": ["knowledge:search:read"] }
      }
    },
    {
      "name": "R3 delegation stays default-deny (the gate pins to R2 only)",
      "expect": "deny",
      "request": {
        "principal": { "type": "User", "id": "user:jane.doe", "attrs": { "tenant": "acme" } },
        "action": "delegate",
        "resource": { "type": "Agent", "id": "change-agent", "attrs": { "tenant": "acme" } },
        "context": { "risk": "R3", "scopes": ["task:submit"] }
      }
    },
    {
      "name": "an unmodeled action falls to default deny",
      "expect": "deny",
      "request": {
        "principal": { "type": "Service", "id": "svc:mystery", "attrs": { "tenant": "acme" } },
        "action": "cloud.tag_apply",
        "resource": { "type": "Agent", "id": "cloud-agent", "attrs": { "tenant": "acme" } },
        "context": { "scopes": ["everything"] }
      }
    }
  ]
}
