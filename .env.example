# Dev-stack configuration. Every variable has a safe local default baked
# into deploy/compose/docker-compose.yml; set values here only to override.
# Real deployments inject secrets via the environment/vault — never commit
# actual credentials.

# Postgres (system of record + pgvector + Temporal persistence)
#ACP_PG_USER=acp
#ACP_PG_PASSWORD=acp-dev-password

# NATS per-service users (accounts: SYS / PLATFORM / TENANT_ACME)
#ACP_NATS_SYS_PASSWORD=sys-dev-password
#ACP_NATS_GATEWAY_PASSWORD=gateway-dev-password
#ACP_NATS_ORCHESTRATOR_PASSWORD=orchestrator-dev-password
#ACP_NATS_REGISTRY_PASSWORD=registry-dev-password
#ACP_NATS_POLICY_PASSWORD=policy-dev-password
#ACP_NATS_AUDIT_PASSWORD=audit-dev-password
#ACP_NATS_KNOWLEDGE_PASSWORD=knowledge-dev-password
#ACP_NATS_TOKEN_PASSWORD=token-dev-password
#ACP_NATS_AGENT_KNOWLEDGE_PASSWORD=agent-knowledge-dev-password

# Session Context Cache (Knowledge Service). Default OFF — off is
# correct-but-uncached. See docs/architecture/knowledge-and-rag.md.
#ACP_SESSION_CACHE_ENABLED=false
#ACP_SESSION_CACHE_TTL_MS=60000
#ACP_SESSION_CACHE_MAX_VALUE_BYTES=262144
#ACP_SESSION_CACHE_MAX_BYTES=67108864

# Seconds `make dev` waits for the stack before failing loudly
#ACP_DEV_WAIT_TIMEOUT=180
