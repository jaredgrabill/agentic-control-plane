{
  "$schema": "https://turborepo.com/schema.json",
  "tasks": {
    "gen": {
      "inputs": ["schemas/**", "scripts/**"],
      "outputs": ["src/generated/**", "../../python/acp-protocol/src/acp_protocol/generated/**"]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"]
    }
  }
}
