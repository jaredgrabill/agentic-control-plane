{
  "name": "@acp/judge",
  "version": "0.1.0",
  "private": true,
  "description": "Calibrated LLM-judge harness: one committed rubric, one prompt template, a fail-closed calibration gate, and a tolerant verdict parser. One rubric, two venues (offline eval gate + online sampled scoring).",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "rubrics",
    "calibration"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json",
    "lint": "eslint .",
    "test": "vitest run --coverage"
  },
  "dependencies": {
    "@acp/llm-client": "workspace:*",
    "ajv": "^8.17.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@vitest/coverage-v8": "^3.2.4",
    "vitest": "^3.2.4"
  }
}
