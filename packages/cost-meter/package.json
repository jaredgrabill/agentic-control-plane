{
  "name": "@acp/cost-meter",
  "version": "0.1.0",
  "private": true,
  "description": "Cost Meter: versioned price book loader and deterministic, isolate-safe pricing math (integer micro-USD)",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./pricing": {
      "types": "./dist/pricing.d.ts",
      "default": "./dist/pricing.js"
    }
  },
  "files": [
    "dist",
    "pricebooks"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json",
    "lint": "eslint .",
    "test": "vitest run --coverage"
  },
  "dependencies": {
    "ajv": "^8.17.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@vitest/coverage-v8": "^3.2.4",
    "vitest": "^3.2.4"
  }
}
