{
  "name": "@acp/agent-sdk",
  "version": "0.1.0",
  "description": "ACP agent SDK for TypeScript: manifest-bound agents, capability handlers, governed model/retrieval access, telemetry, eval harness",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json",
    "lint": "eslint .",
    "test": "vitest run --coverage"
  },
  "dependencies": {
    "@acp/protocol": "workspace:*",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.203.0",
    "@opentelemetry/resources": "^2.0.1",
    "@opentelemetry/sdk-trace-node": "^2.0.1",
    "@temporalio/common": "^1.13.0",
    "@temporalio/interceptors-opentelemetry": "^1.13.0",
    "@temporalio/worker": "^1.13.0",
    "ajv": "^8.17.1",
    "nats": "^2.29.3",
    "pino": "^9.7.0",
    "yaml": "^2.8.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@vitest/coverage-v8": "^3.2.4",
    "vitest": "^3.2.4"
  }
}
