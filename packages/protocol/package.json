{
  "name": "@acp/protocol",
  "version": "0.2.0",
  "description": "Single source of truth for cross-language contracts: JSON Schemas plus generated TypeScript bindings, subject vocabulary, and runtime validators",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "schemas"
  ],
  "scripts": {
    "gen": "node scripts/generate.mjs",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json",
    "lint": "eslint .",
    "test": "vitest run --coverage"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@vitest/coverage-v8": "^3.2.4",
    "json-schema-to-typescript": "^15.0.4",
    "vitest": "^3.2.4"
  }
}
