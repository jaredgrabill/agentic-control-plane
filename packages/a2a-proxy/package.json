{
  "name": "@acp/a2a-proxy",
  "version": "0.1.0",
  "description": "Thin proxy adapter over @acp/agent-sdk: serves a registered proxy agent's task queue and forwards capabilities to a remote A2A endpoint with the adapter's OWN credential — the broker delegated token never egresses",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json",
    "lint": "eslint .",
    "test": "vitest run --coverage"
  },
  "dependencies": {
    "@acp/agent-sdk": "workspace:*",
    "@acp/protocol": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@vitest/coverage-v8": "^3.2.4",
    "vitest": "^3.2.4"
  }
}
