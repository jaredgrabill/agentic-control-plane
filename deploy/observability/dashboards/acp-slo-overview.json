{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["acp", "slo"],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "",
  "title": "ACP - SLO Overview",
  "uid": "acp-slo-overview",
  "version": 1,
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Task e2e latency p95 (SLO < 30s)",
      "description": "SLO 2a. Assumes acp_task_duration_seconds histogram.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 30
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "acp:task_duration_seconds:p95_5m",
          "legendFormat": "{{acp_agent_id}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Queue depth / backlog (drains to ~0)",
      "description": "SLO 3. Assumes acp_queue_depth gauge.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "acp_queue_depth",
          "legendFormat": "{{acp_agent_id}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Retrieval hit rate (>= baseline)",
      "description": "SLO 4a. Assumes acp_retrieval_hit_total / acp_retrieval_total counters.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(acp_retrieval_hit_total[10m])) / clamp_min(sum(rate(acp_retrieval_total[10m])), 1)",
          "legendFormat": "hit rate"
        }
      ]
    },
    {
      "id": 4,
      "type": "gauge",
      "title": "Budget burn_ratio (0.5 warn / 1.0 exhausted)",
      "description": "SLO 5a. Mirrors online-eval/budget.ts. Assumes acp_budget_burn_ratio gauge.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "min": 0,
          "max": 1.5,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.5
              },
              {
                "color": "red",
                "value": 1.0
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max by (acp_tenant, acp_agent_id) (acp_budget_burn_ratio)",
          "legendFormat": "{{acp_tenant}}/{{acp_agent_id}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Quality state (0=measurable ... 4=floor)",
      "description": "SLO 5b. Mirrors online-eval/ladder.ts. Assumes acp_quality_state gauge.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 2
              }
            ]
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "measurable"
                },
                "1": {
                  "text": "warning"
                },
                "2": {
                  "text": "exhausted"
                },
                "3": {
                  "text": "severe"
                },
                "4": {
                  "text": "floor"
                }
              }
            }
          ]
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max by (acp_agent_id) (acp_quality_state)",
          "legendFormat": "{{acp_agent_id}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Audit append lag p95 (SLO < 5s) + chain verified",
      "description": "SLO 6. Assumes acp_audit_append_lag_seconds histogram and acp_audit_chain_verified gauge.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "acp:audit_append_lag_seconds:p95_5m",
          "legendFormat": "append lag p95"
        },
        {
          "refId": "B",
          "expr": "acp_audit_chain_verified",
          "legendFormat": "chain verified (1=ok)"
        }
      ]
    }
  ]
}
