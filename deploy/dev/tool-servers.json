{
  "schema": "acp-tool-servers/v1",
  "servers": [
    {
      "id": "cloud-estate",
      "url": "http://localhost:7301/mcp",
      "auth": {
        "mode": "static-headers",
        "headers": {
          "x-acp-broker-credential": "${ACP_TOOL_CRED_CLOUD_ESTATE:-cloud-estate-dev-broker}"
        }
      },
      "tools": {
        "inventory_search": { "scope": "cloud:inventory:read", "risk": "R0" },
        "cost_report": { "scope": "cloud:cost:read", "risk": "R0" },
        "tag_apply": { "scope": "cloud:tag:write", "risk": "R2" },
        "tag_remove": { "scope": "cloud:tag:write", "risk": "R2" }
      },
      "rate_limit": { "per_minute": 60, "burst": 20 },
      "timeout_ms": 15000
    },
    {
      "id": "code-forge",
      "url": "http://localhost:7302/mcp",
      "auth": {
        "mode": "static-headers",
        "headers": {
          "x-acp-broker-credential": "${ACP_TOOL_CRED_CODE_FORGE:-code-forge-dev-broker}"
        }
      },
      "tools": {
        "repo_dependencies": { "scope": "code:repo:read", "risk": "R0" },
        "ci_runs": { "scope": "code:ci:read", "risk": "R0" }
      },
      "rate_limit": { "per_minute": 60, "burst": 20 }
    },
    {
      "id": "itsm",
      "url": "http://localhost:7303/mcp",
      "auth": {
        "mode": "static-headers",
        "headers": {
          "x-acp-broker-credential": "${ACP_TOOL_CRED_ITSM:-itsm-dev-broker}"
        }
      },
      "tools": {
        "change_get": { "scope": "itsm:change:read", "risk": "R0" },
        "change_record_lookup": { "scope": "itsm:change:read", "risk": "R0" },
        "calendar_conflicts": { "scope": "itsm:calendar:read", "risk": "R0" },
        "change_create_draft": { "scope": "itsm:change:draft", "risk": "R1" },
        "change_submit": { "scope": "itsm:change:submit", "risk": "R2" },
        "change_withdraw": { "scope": "itsm:change:withdraw", "risk": "R2" }
      },
      "rate_limit": { "per_minute": 60, "burst": 20 }
    },
    {
      "id": "netsec",
      "url": "http://localhost:7304/mcp",
      "auth": {
        "mode": "static-headers",
        "headers": {
          "x-acp-broker-credential": "${ACP_TOOL_CRED_NETSEC:-netsec-dev-broker}"
        }
      },
      "tools": {
        "firewall_rules_search": { "scope": "netsec:firewall:read", "risk": "R0" },
        "security_group_get": { "scope": "netsec:secgroup:read", "risk": "R0" },
        "ipam_lookup": { "scope": "netsec:ipam:read", "risk": "R0" },
        "vuln_scan_report": { "scope": "netsec:vuln:read", "risk": "R0" }
      },
      "rate_limit": { "per_minute": 60, "burst": 20 }
    },
    {
      "id": "knowledge",
      "url": "http://localhost:7105/mcp",
      "auth": {
        "mode": "token-exchange",
        "audience": "acp:knowledge",
        "scope": ["knowledge:search:read"]
      },
      "tools": {
        "knowledge_search": { "scope": "knowledge:search:read", "risk": "R0" }
      },
      "rate_limit": { "per_minute": 60, "burst": 5 }
    }
  ]
}
