{
  "name": "@acp/mock-tools",
  "version": "0.1.0",
  "private": true,
  "description": "Mock MCP tool servers (cloud-estate, code-forge) serving the acme-corp fixtures with scripted failure modes",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
