{
  "name": "@acp/external-echo-agent",
  "version": "0.1.0",
  "private": true,
  "description": "External-echo proxy agent v0: forwards its capability to a remote A2A endpoint through the @acp/a2a-proxy adapter (delegated token never egresses)",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json",
    "lint": "eslint .",
    "test": "vitest run --coverage"
  },
  "dependencies": {
    "@acp/a2a-proxy": "workspace:*",
    "@acp/agent-sdk": "workspace:*",
    "@acp/tool-client": "workspace:*"
  },
  "devDependencies": {
    "@acp/protocol": "workspace:*",
    "@temporalio/common": "^1.13.0",
    "@types/node": "^22.15.0",
    "@vitest/coverage-v8": "^3.2.4",
    "vitest": "^3.2.4"
  }
}
